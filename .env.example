# Server Configuration
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/tinder-clone

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Super Like Configuration
SUPER_LIKE_DAILY_LIMIT=1
SUPER_LIKE_RESET_HOUR=0

# Notification Service
NOTIFICATION_SERVICE_URL=https://api.notifications.com
NOTIFICATION_API_KEY=your-notification-api-key
